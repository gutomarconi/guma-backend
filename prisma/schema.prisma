generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  apiKeys   ApiKey[]
}

model User {
  id        Int      @id @default(autoincrement())
  companyId Int?
  name      String   @default("")
  email     String   @unique
  senha     String
  role      String   @default("user")
  createdAt DateTime @default(now())
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([id], map: "idx_user_id")
  @@index([companyId], map: "idx_po_companyid")
}

model ApiKey {
  id          Int      @id @default(autoincrement())
  companyId   Int
  key         String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id])
}

model PO {
  id          Int       @id @default(autoincrement())
  description String
  createdAt   DateTime  @default(now())
  Machine     Machine[]
  routes      ProductRoute[]

  @@index([id], map: "idx_po_id")
}

enum CapacityUnity {
  M2
  UN
  M3
  M
}

model Machine {
  id             Int           @id @default(autoincrement())
  companyId      Int
  description    String
  createdAt      DateTime      @default(now())
  poId           Int
  capacity       Float
  capacity_unity CapacityUnity @default(M2)
  unity_cost     Float
  po             PO            @relation(fields: [poId], references: [id])
  
  OrderItemHistory             OrderItemHistory[]

  @@index([id], map: "idx_machine_id")
  @@index([poId], map: "idx_machine_poid")
}

model FileMapping {
  id          Int  @id @default(autoincrement())
  companyId   Int
  mapping     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MachineFingerprint {
  id          Int  @id @default(autoincrement())
  companyId   Int
  fingerprint String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  machineId   Int
}

model OrderStats {
  order_number  Int
  companyId     Int
  delivery_date DateTime @default(now())
  total_items Int
  items_done  Int
  first_read_date DateTime @default(now())
  last_read_date DateTime @default(now())

  @@id([companyId, order_number])
  @@index([companyId], map: "idx_order_stats_company")
}

model ItemHistoryFailed {
  id        Int  @id @default(autoincrement())
  companyId Int
  machineId Int
  barcode   String
  createdAt DateTime      @default(now())
  readDate  DateTime      @default(now())

  @@index([companyId, machineId], map: "idx_itemhistoryfailed_company_machine")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Order {
  id            Int      @id @default(autoincrement())
  company_id    Int
  order_number  Int
  customer_name String
  order_date    DateTime
  delivery_date DateTime
  buy_order     String
  load_number   String
  createdAt     DateTime @default(now())
  batch_number  Int
  box_mumber    Int?
  customer_id   Int @default(1)

  items OrderItem[]
  progress       OrderProgress?
  customer Customer @relation(fields: [customer_id], references: [id])

  @@unique([company_id, order_number])
  @@index([company_id, order_date])
  @@index([company_id, customer_id])
}

model Product {
  id              Int    @id @default(autoincrement())
  company_id      Int
  item_code       String
  description     String
  cubic_meter     Float  @default(0)
  linear_meter    Float  @default(0)
  square_meter    Float  @default(0)
  material_cut    String @default("")
  material_border String @default("")
  created_at      DateTime @default(now())
  planner         String?

  routes    ProductRoute[]
  OrderItem OrderItem[]

  @@unique([company_id, item_code])
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  company_id Int
  order_id   Int
  product_id Int
  order      Order   @relation(fields: [order_id], references: [id])
  product    Product @relation(fields: [product_id], references: [id])

  barcode    String   @unique
  quantity   Float
  created_at DateTime @default(now())

  OrderItemHistory OrderItemHistory[]

  @@unique([barcode, company_id], map: "idx_orderitem_barcode_companyid_unique")
  @@index([company_id, order_id])
  @@index([barcode])
}

model ProductRoute {
  id         Int @id @default(autoincrement())
  product_id Int
  po_id      Int
  sequence   Int
  created_at      DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id])
  po      PO      @relation(fields: [po_id], references: [id])

  @@index([product_id, sequence])
  @@unique([product_id, po_id])
}

model OrderItemHistory {
  id            Int      @id @default(autoincrement())
  company_id    Int
  order_item_id Int
  product_id    Int
  po_id         Int
  machine_id    Int
  created_at    DateTime @default(now())
  read_date     DateTime @default(now())
  reading_type  ReadingType?

  orderItem OrderItem @relation(fields: [order_item_id], references: [id])
  machine Machine @relation(fields: [machine_id], references: [id])

  @@index([order_item_id, po_id])
  @@index([machine_id, read_date])
  @@index([po_id, read_date])
}

model OrderProgress {
  order_id        Int     @id
  company_id      Int

  total_items     Int     @default(0)

  cutting_total   Int     @default(0)
  cutting_done    Int     @default(0)

  drilling_total  Int     @default(0)
  drilling_done   Int     @default(0)

  border_total    Int     @default(0)
  border_done     Int     @default(0)

  packaging_total Int     @default(0)
  packaging_done  Int     @default(0)

  items_started   Int     @default(0)
  items_finished  Int     @default(0)

  first_read_date DateTime?
  last_read_date  DateTime?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  order           Order @relation(fields: [order_id], references: [id])

  @@index([company_id])
}

enum ReadingType {
  Retrabalho
  Refugo
  Normal
  Outro
}

model Customer {
  id            Int      @id @default(autoincrement())
  company_id    Int
  customer_name String
  id_number     String
  createdAt     DateTime @default(now())

  orders         Order[]
  
  @@unique([company_id, id_number])
  @@index([company_id, id])
  @@index([company_id, id_number])
}
